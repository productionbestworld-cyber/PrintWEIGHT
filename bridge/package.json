{
  "name": "bwp-scale-bridge",
  "version": "1.0.0",
  "description": "Local bridge - reads weight scale via serial and broadcasts via WebSocket",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/BWPScaleBridge.exe"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "ws": "^8.18.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1"
  },
  "pkg": {
    "assets": [
      "node_modules/@serialport/bindings-cpp/prebuilds/**/*"
    ],
    "scripts": [
      "server.js"
    ]
  }
}
